# Copy this file to .env and fill in real values. .env is gitignored.

# ---- MT5 (Vantage Markets) ----
# Get these from your Vantage demo or live account.
# MT5_PATH points to the MetaTrader 5 desktop install — required because
# the MetaTrader5 Python library launches/attaches to the local terminal.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ---- Supabase ----
# SUPABASE_URL: your project URL, e.g. https://xxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: used by the bot (bypasses RLS — keep secret).
# SUPABASE_ANON_KEY: used by the dashboard later (Phase E).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ---- Finnhub ----
# Used by the Vercel cron route (not the bot directly — see spec Section 8.2).
# Kept here so a single .env covers local testing of the cron route too.
FINNHUB_API_KEY=

# ---- Telegram alerts (optional, Phase E) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
