# Supabase project URL — visible in the Supabase dashboard under
# Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — visible in the Supabase dashboard
# under Project Settings → API → Project API keys → anon / public.
# Safe to expose: the `signals` table has a SELECT-only RLS policy
# for the anon role (migration 014). Writes still require the
# service_role key, which lives only on the bot.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
